# Ignition version
IGNITION_VERSION=8.1.33

# Gateway ports
GATEWAY_HTTP_PORT=8088
GATEWAY_HTTPS_PORT=8043

# PostgreSQL - DEV
POSTGRES_DB=ignition_dev
POSTGRES_USER=ignition_dev
POSTGRES_PASSWORD=devpassword123

# DB connection (used inside Docker network)
DB_HOST=postgres
DB_PORT=5432

# Ignition gateway credentials
GATEWAY_ADMIN_USERNAME=admin
GATEWAY_ADMIN_PASSWORD=password

IGNITION_EDITION=standard
